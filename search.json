---
layout: null
---
[
  {% for post in site.posts %
  }
    {
    "title": {
      { post.title | jsonify
      }
    },
    "category": {
      { post.category | jsonify
      }
    },
    "tags": {
      { post.tags | join: ', ' | jsonify
      }
    },
    "url": {
      { post.url | relative_url | jsonify
      }
    },
    "date": {
      { post.date | date: "%Y-%m-%d" | jsonify
      }
    }
  }{% unless forloop.last %
  },
  {% endunless %
  }
  {% endfor %
  }
]